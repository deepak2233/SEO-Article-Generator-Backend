# ─── LLM Configuration ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=         # Optional: for proxies or alternative endpoints
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# ─── SERP Provider ───────────────────────────────────────────────────────
SERP_PROVIDER=mock          # mock | serpapi | valueserp
SERP_API_KEY=               # Required for serpapi/valueserp

# ─── Job Storage ─────────────────────────────────────────────────────────
# JOB_STORE_DIR=~/.seo_agent_jobs

# ─── Quality Settings ───────────────────────────────────────────────────
QUALITY_THRESHOLD=6.0
MAX_REVISION_ROUNDS=2
